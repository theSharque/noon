    <button type="button" id="btn-play-on" title="Пауза"><img src="img/topmenu/btn_player_on.png?v=4" width="27" height="21" alt="pause"></button>
    <button type="button" id="btn-next" title="Следующий"><img src="img/topmenu/btn_player_next.png?v=4" width="27" height="21" alt="next"></button>
    <a id="btn-mail" href="page.php?id=1&amp;sp=1" target="main" title="Почта"></a>
  </div>
</div>
<audio id="player" preload="none"></audio>
<audio id="snd-hover" preload="auto" src="img/topmenu/sound7.wav"></audio>
<audio id="snd-click" preload="auto" src="img/topmenu/bleep.wav"></audio>
<script>
(function () {
  var mv = {$mv};
  var sv = {$sv};
  var mailId = 0;
  var trackIndex = Math.floor(Math.random() * 9);
  var playing = false;
  var playlist = [
    'music/1.mp3', 'music/2.mp3', 'music/3.mp3', 'music/4.mp3', 'music/5.mp3',
    'music/6.mp3', 'music/7.mp3', 'music/8.mp3', 'music/9.mp3'
  ];
  var player = document.getElementById('player');
  var sndHover = document.getElementById('snd-hover');
  var sndClick = document.getElementById('snd-click');
  var btnPlayOn = document.getElementById('btn-play-on');
  var btnPlayOff = document.getElementById('btn-play-off');
  var btnMail = document.getElementById('btn-mail');
  var pingEl = document.getElementById('ping');

  function sfxVolume() {
    var v = Math.max(0, Math.min(1, sv / 100));
    sndHover.volume = v;
    sndClick.volume = v;
  }
  sfxVolume();

  function playHover() {
    try { sndHover.pause(); sndHover.currentTime = 0; sndHover.play(); } catch (e) {}
  }
  function playClick() {
    try { sndClick.pause(); sndClick.currentTime = 0; sndClick.play(); } catch (e) {}
  }

  Array.prototype.forEach.call(document.querySelectorAll('#nav a, #tools a, #tools button'), function (el) {
    el.addEventListener('mouseenter', playHover);
    el.addEventListener('mousedown', playClick);
  });

  function loadTrack(idx) {
    trackIndex = ((idx % playlist.length) + playlist.length) % playlist.length;
    player.src = playlist[trackIndex];
    player.load();
  }
  function setMusicVolume(vol) {
    player.volume = Math.max(0, Math.min(1, vol / 100));
  }
  function updatePlayBtns() {
    btnPlayOn.hidden = playing;
    btnPlayOff.hidden = !playing;
  }
  function playMusic() {
    setMusicVolume(mv);
    player.play().catch(function () {});
    playing = true;
    updatePlayBtns();
  }
  function pauseMusic() {
    player.pause();
    playing = false;
    updatePlayBtns();
  }
  function toggleMusic() {
    if (playing) pauseMusic();
    else {
      if (!player.src) loadTrack(trackIndex);
      playMusic();
    }
  }
  function nextTrack() {
    loadTrack(trackIndex + 1);
    if (playing) playMusic();
  }
  player.addEventListener('ended', nextTrack);
  btnPlayOn.addEventListener('click', toggleMusic);
  btnPlayOff.addEventListener('click', toggleMusic);
  document.getElementById('btn-next').addEventListener('click', nextTrack);

  function setPing(ms) {
    if (ms === null || isNaN(ms)) { pingEl.textContent = ''; return; }
    pingEl.textContent = String(ms);
    pingEl.className = '';
    if (ms <= 1000) return;
    if (ms <= 3000) pingEl.className = 'warn';
    else pingEl.className = 'bad';
  }

  function parseVars(text) {
    var out = {};
    text.split('&').forEach(function (pair) {
      var i = pair.indexOf('=');
      if (i < 0) return;
      out[pair.slice(0, i)] = pair.slice(i + 1);
    });
    return out;
  }

  function pollMail() {
    var ts = Date.now();
    fetch('page.php?id=15&li=' + mailId + '&p=' + ts, { credentials: 'same-origin' })
      .then(function (r) { return r.text(); })
      .then(function (text) {
        var data = parseVars(text.replace(/&eof=1$/, ''));
        var sent = parseInt(data.png, 10);
        if (!isNaN(sent)) setPing(ts - sent);
        if (parseInt(data.err, 10) === 0) {
          mailId = parseInt(data.id, 10) || mailId;
          btnMail.classList.add('has-mail');
        } else {
          btnMail.classList.remove('has-mail');
        }
        if (data.mv !== undefined) {
          mv = parseInt(data.mv, 10);
          if (playing) setMusicVolume(mv);
        }
        if (data.sv !== undefined) {
          sv = parseInt(data.sv, 10);
          sfxVolume();
        }
      })
      .catch(function () {
        pingEl.textContent = '!';
        pingEl.className = 'bad';
      });
  }

  pollMail();
  setInterval(pollMail, 15000);

  loadTrack(trackIndex);
  updatePlayBtns();
  if (mv > 0) playMusic();
  else pauseMusic();
})();
</script>
</body>
